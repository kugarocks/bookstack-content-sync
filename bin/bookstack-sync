#!/usr/bin/env bash

set -euo pipefail

CONFIG_DIR="$HOME/.config/bookstack-content-sync"
CONFIG_FILE="$CONFIG_DIR/config.json"
SYNC_JSON="sync.json"

usage() {
    local cyan='\033[0;36m'
    local yellow='\033[1;33m'
    local green='\033[0;32m'
    local reset='\033[0m'

    printf >&2 "\n"
    printf >&2 "${yellow}Usage:${reset}\n"
    printf >&2 "  ${green}bookstack-sync${reset} ${cyan}<command>${reset} ${green}[options]${reset}\n"
    printf >&2 "\n"
    printf >&2 "${yellow}Commands:${reset}\n"
    printf >&2 "  ${cyan}pull${reset}                             Pull content from BookStack\n"
    printf >&2 "  ${cyan}push${reset} ${green}[--execute]${reset}                 Generate or execute push plan\n"
    printf >&2 "  ${cyan}init${reset} ${green}<content-path>${reset} ${green}[options]${reset}    Initialize content directory\n"
    printf >&2 "  ${cyan}config set-bookstack-path${reset} ${green}<path>${reset} Persist global BookStack path\n"
    printf >&2 "\n"
}

error() {
    echo "Error: $1" >&2
    exit 1
}

read_sync_bookstack_path() {
    if [[ ! -f "$SYNC_JSON" ]]; then
        return 0
    fi

    php -r "
        \$data = json_decode(file_get_contents('$SYNC_JSON'), true);
        if (!is_array(\$data)) {
            fwrite(STDERR, 'Error: invalid JSON in sync.json' . PHP_EOL);
            exit(1);
        }
        if (!isset(\$data['bookstack_path'])) {
            exit(0);
        }
        if (!is_string(\$data['bookstack_path']) || trim(\$data['bookstack_path']) === '') {
            fwrite(STDERR, 'Error: sync.json field bookstack_path must be a non-empty string' . PHP_EOL);
            exit(1);
        }
        echo \$data['bookstack_path'];
    "
}

read_global_bookstack_path() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        return 0
    fi

    php -r "
        \$data = json_decode(file_get_contents('$CONFIG_FILE'), true);
        if (!is_array(\$data)) {
            fwrite(STDERR, 'Error: invalid JSON in $CONFIG_FILE' . PHP_EOL);
            exit(1);
        }
        if (!isset(\$data['bookstack_path'])) {
            exit(0);
        }
        if (!is_string(\$data['bookstack_path']) || trim(\$data['bookstack_path']) === '') {
            fwrite(STDERR, 'Error: config field bookstack_path must be a non-empty string' . PHP_EOL);
            exit(1);
        }
        echo \$data['bookstack_path'];
    "
}

resolve_bookstack_path() {
    local sync_path
    local global_path

    sync_path="$(read_sync_bookstack_path)"
    if [[ -n "$sync_path" ]]; then
        echo "$sync_path"
        return 0
    fi

    global_path="$(read_global_bookstack_path)"
    if [[ -n "$global_path" ]]; then
        echo "$global_path"
        return 0
    fi

    error "bookstack_path not found. Set sync.json bookstack_path or run: bookstack-sync config set-bookstack-path /path/to/bookstack"
}

set_global_bookstack_path() {
    local path="$1"

    [[ -d "$path" ]] || error "BookStack directory not found at [$path]"
    [[ -f "$path/artisan" ]] || error "artisan not found at [$path/artisan]"

    mkdir -p "$CONFIG_DIR"

    php -r "
        \$path = \$argv[1];
        \$json = json_encode(['bookstack_path' => \$path], JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES);
        if (\$json === false) {
            fwrite(STDERR, 'Error: failed to encode config JSON' . PHP_EOL);
            exit(1);
        }
        file_put_contents(\$argv[2], \$json . PHP_EOL);
    " "$path" "$CONFIG_FILE"

    echo "Saved bookstack_path to $CONFIG_FILE"
}

resolve_artisan() {
    local bookstack_path="$1"

    [[ -d "$bookstack_path" ]] || error "BookStack directory not found at [$bookstack_path]"

    local artisan="$bookstack_path/artisan"
    [[ -f "$artisan" ]] || error "artisan not found at [$artisan]"

    echo "$artisan"
}

command="${1:-}"

case "$command" in
    pull)
        shift
        artisan="$(resolve_artisan "$(resolve_bookstack_path)")"
        php "$artisan" bookstack:pull-content . "$@"
        ;;
    push)
        shift
        artisan="$(resolve_artisan "$(resolve_bookstack_path)")"
        php "$artisan" bookstack:push-content . "$@"
        ;;
    init)
        shift
        [[ $# -ge 1 ]] || error "init requires content path"
        content_path="$1"
        shift
        bookstack_path="$(resolve_bookstack_path)"
        artisan="$(resolve_artisan "$bookstack_path")"
        php "$artisan" bookstack:init-content-dir "$content_path" --bookstack-path="$bookstack_path" "$@"
        ;;
    config)
        subcommand="${2:-}"
        case "$subcommand" in
            set-bookstack-path)
                [[ $# -eq 3 ]] || error "Usage: bookstack-sync config set-bookstack-path /path/to/bookstack"
                set_global_bookstack_path "$3"
                ;;
            *)
                error "Unknown config command [$subcommand]"
                ;;
        esac
        ;;
    ""|-h|--help|help)
        usage
        ;;
    *)
        error "unknown command [$command]"
        ;;
esac
